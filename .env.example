# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Gemini API Configuration
# Required for Gemini AI API calls
# AI Studio automatically injects this at runtime from user secrets
# Users configure this via the Secrets panel in the AI Studio UI
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Application URL
# The URL where this applet is hosted
# AI Studio automatically injects this at runtime with the Cloud Run service URL
# Used for self-referential links, OAuth callbacks, and API endpoints
APP_URL="MY_APP_URL"

# MongoDB Backup Connection String
# Get this from MongoDB Atlas connection string
MONGODB_BACKUP_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/payments?authSource=admin

# Stripe API Keys
# Get these from your Stripe Dashboard (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=your_stripe_public_key_here

# Database Configuration
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=sentinel_compliance
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# Application Configuration
# NODE_ENV=development
# PORT=3000

# Add any other environment variables your application needs below
